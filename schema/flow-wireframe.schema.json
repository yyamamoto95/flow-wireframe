{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://unpkg.com/flow-wireframe/schema/flow-wireframe.schema.json",
  "title": "flow-wireframe フロー定義",
  "description": "業務フロー定義。screens（画面カタログ）と flows（ユーザーストーリー単位の業務フロー）で構成する。",
  "type": "object",
  "required": [
    "title",
    "screens",
    "flows"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "lang": {
      "enum": [
        "ja",
        "en"
      ],
      "description": "出力ドキュメントの定型文言の言語（凡例・見出し・Gherkin行ラベル等）。省略時は日本語"
    },
    "title": {
      "type": "string",
      "description": "ドキュメント名"
    },
    "description": {
      "type": "string",
      "description": "ドキュメントの説明"
    },
    "version": {
      "type": "string",
      "description": "定義のバージョン。出力HTMLに表示される"
    },
    "accent": {
      "type": "string",
      "description": "アクセントカラー（CSSカラー値）"
    },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/screen"
      }
    },
    "flows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/flow"
      }
    },
    "glossary": {
      "type": "array",
      "description": "ユビキタス言語の用語集（ことばの層）",
      "items": {
        "type": "object",
        "required": [
          "term",
          "definition"
        ],
        "additionalProperties": false,
        "properties": {
          "term": {
            "type": "string"
          },
          "definition": {
            "type": "string"
          },
          "entity": {
            "type": "string",
            "description": "対応するエンティティID（entities を参照）"
          }
        }
      }
    },
    "entities": {
      "type": "array",
      "description": "ビジネス用語とテーブルの写像（データの層）。スキーマのSSOTは実装側にあり、ここはその写し",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "step.data から参照される一意なID"
          },
          "name": {
            "type": "string",
            "description": "ビジネス用語（ユビキタス言語）での名前"
          },
          "table": {
            "type": "string",
            "description": "物理テーブル名"
          },
          "note": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name"
              ],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                  "description": "物理カラム名"
                },
                "label": {
                  "type": "string",
                  "description": "ビジネス上の呼び名"
                },
                "note": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "screen": {
      "type": "object",
      "required": [
        "id",
        "name",
        "elements"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "フロー・goto から参照する一意なID"
        },
        "name": {
          "type": "string",
          "description": "画面名"
        },
        "note": {
          "type": "string",
          "description": "画面の目的や状態の説明"
        },
        "layout": {
          "enum": [
            "mobile",
            "desktop",
            "terminal"
          ],
          "description": "mobile=スマホ枠(320px) / desktop=ブラウザ枠(560px) / terminal=端末枠(560px・CLI用)。省略時は mobile"
        },
        "elements": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/element"
          }
        }
      }
    },
    "element": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "header",
            "text",
            "input",
            "button",
            "link",
            "list",
            "card",
            "chart",
            "image",
            "badge",
            "choice",
            "nav",
            "divider",
            "console"
          ]
        },
        "note": {
          "type": "string",
          "description": "①②…として画面下の注釈リストに表示される補足"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "header"
              }
            }
          },
          "then": {
            "required": [
              "type",
              "label"
            ],
            "properties": {
              "label": {
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "text"
              }
            }
          },
          "then": {
            "required": [
              "type",
              "label"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "muted": {
                "type": "boolean"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "input"
              }
            }
          },
          "then": {
            "required": [
              "type",
              "label"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "placeholder": {
                "type": "string"
              },
              "secret": {
                "type": "boolean"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "button"
              }
            }
          },
          "then": {
            "required": [
              "type",
              "label"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "goto": {
                "type": "string",
                "description": "クリックで遷移する画面ID"
              },
              "variant": {
                "enum": [
                  "primary",
                  "secondary",
                  "danger"
                ]
              },
              "external": {
                "type": "boolean",
                "description": "外部サービスへの遷移（↗表示）"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "link"
              }
            }
          },
          "then": {
            "required": [
              "type",
              "label"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "goto": {
                "type": "string"
              },
              "external": {
                "type": "boolean"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "list"
              }
            }
          },
          "then": {
            "required": [
              "type",
              "items"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "items": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "card"
              }
            }
          },
          "then": {
            "required": [
              "type",
              "label"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "value": {
                "type": "string",
                "description": "カードの主役となる値（例: ¥1,280）"
              },
              "caption": {
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "chart"
              }
            }
          },
          "then": {
            "properties": {
              "label": {
                "type": "string"
              },
              "kind": {
                "enum": [
                  "bar",
                  "line",
                  "donut"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "image"
              }
            }
          },
          "then": {
            "properties": {
              "label": {
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "badge"
              }
            }
          },
          "then": {
            "required": [
              "type",
              "label"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "tone": {
                "enum": [
                  "good",
                  "caution",
                  "neutral"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "choice"
              }
            }
          },
          "then": {
            "required": [
              "type",
              "items"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "items": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "selected": {
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "nav"
              }
            }
          },
          "then": {
            "required": [
              "type",
              "items"
            ],
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "object",
                      "required": [
                        "label"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "label": {
                          "type": "string"
                        },
                        "goto": {
                          "type": "string"
                        }
                      }
                    }
                  ]
                }
              },
              "selected": {
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "console"
              }
            }
          },
          "then": {
            "required": [
              "type",
              "lines"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "lines": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "等幅表示する行。行頭 \"$ \" はコマンド、\"? \" は対話プロンプトとして強調"
              }
            }
          }
        }
      ]
    },
    "flow": {
      "type": "object",
      "required": [
        "id",
        "name",
        "steps"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "トレーサビリティID（例: US-301）"
        },
        "name": {
          "type": "string"
        },
        "actor": {
          "type": "string",
          "description": "フローの主体（例: 利用者、システム）"
        },
        "description": {
          "type": "string"
        },
        "scenario": {
          "type": "object",
          "required": [
            "given",
            "when",
            "then"
          ],
          "additionalProperties": false,
          "properties": {
            "given": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "前提"
            },
            "when": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "操作"
            },
            "then": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "結果"
            }
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "screen": {
                "type": "string",
                "description": "表示する画面のID（process と排他）"
              },
              "process": {
                "type": "string",
                "description": "画面を持たない処理の名前（screen と排他）"
              },
              "actor": {
                "type": "string",
                "description": "このステップの主体。省略時はフローの actor"
              },
              "action": {
                "type": "string",
                "description": "次のステップへの矢印ラベル"
              },
              "result": {
                "type": "string",
                "description": "システムの応答・特記事項"
              },
              "data": {
                "type": "array",
                "description": "このステップでデータ（テーブル）がどう変わるか",
                "items": {
                  "type": "object",
                  "required": [
                    "entity",
                    "change"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "entity": {
                      "type": "string",
                      "description": "entities のID"
                    },
                    "change": {
                      "enum": [
                        "create",
                        "read",
                        "update",
                        "delete"
                      ]
                    },
                    "columns": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "影響するカラム名"
                    },
                    "note": {
                      "type": "string",
                      "description": "非エンジニア向けの補足"
                    }
                  }
                }
              }
            },
            "oneOf": [
              {
                "required": [
                  "screen"
                ]
              },
              {
                "required": [
                  "process"
                ]
              }
            ]
          }
        }
      }
    }
  }
}
