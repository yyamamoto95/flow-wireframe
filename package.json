{
  "name": "flow-wireframe",
  "version": "0.6.0",
  "description": "業務フロー定義(JSON)から、非エンジニアにも読める自己完結型の静的HTMLワイヤーフレームを生成するライブラリ / CLI",
  "keywords": [
    "wireframe",
    "bdd",
    "gherkin",
    "prototyping",
    "static-html",
    "user-flow"
  ],
  "license": "MIT",
  "author": "yyamamoto95",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yyamamoto95/flow-wireframe.git"
  },
  "homepage": "https://github.com/yyamamoto95/flow-wireframe#readme",
  "bugs": {
    "url": "https://github.com/yyamamoto95/flow-wireframe/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "flow-wireframe": "dist/cli.js"
  },
  "files": [
    "dist",
    "schema",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run",
    "example": "tsc && node dist/cli.js build examples/kakeibo.flow.json -o examples/kakeibo.wireframe.html"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
